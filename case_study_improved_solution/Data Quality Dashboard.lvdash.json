{
  "datasets": [
    {
      "name": "6bf18a50",
      "displayName": "dq_control",
      "config": {
        "version": "1.1",
        "source": "case_study.gold.dq_control",
        "dimensions": [
          {
            "name": "check_name",
            "expr": "source.check_name",
            "displayName": "Check Name"
          },
          {
            "name": "check_type",
            "expr": "source.check_type",
            "displayName": "Check Type"
          },
          {
            "name": "checked_at",
            "expr": "source.checked_at",
            "displayName": "Checked At"
          },
          {
            "name": "checked_ts",
            "expr": "CAST(source.checked_at AS TIMESTAMP)",
            "displayName": "Checked Timestamp"
          },
          {
            "name": "checked_day",
            "expr": "DATE_TRUNC('DAY', CAST(source.checked_at AS TIMESTAMP))",
            "displayName": "Checked Day"
          },
          {
            "name": "failed_rows",
            "expr": "source.failed_rows",
            "displayName": "Failed Rows"
          },
          {
            "name": "layer",
            "expr": "source.layer",
            "displayName": "Layer"
          },
          {
            "name": "status",
            "expr": "source.status",
            "displayName": "Status"
          },
          {
            "name": "table_name",
            "expr": "source.table_name",
            "displayName": "Table Name"
          },
          {
            "name": "total_rows",
            "expr": "source.total_rows",
            "displayName": "Total Rows"
          }
        ],
        "measures": [
          {
            "name": "count",
            "expr": "COUNT(*)",
            "comment": "Represents the total number of rows in the dataset.",
            "displayName": "Count"
          },
          {
            "name": "total_checks",
            "expr": "COUNT(*)",
            "displayName": "Total Checks",
            "comment": "Total number of executed checks."
          },
          {
            "name": "failed_checks",
            "expr": "SUM(CASE WHEN source.status = 'FAIL' THEN 1 ELSE 0 END)",
            "displayName": "Failed Checks",
            "comment": "Total number of failed checks."
          },
          {
            "name": "passed_checks",
            "expr": "SUM(CASE WHEN source.status = 'PASS' THEN 1 ELSE 0 END)",
            "displayName": "Passed Checks",
            "comment": "Total number of passed checks."
          },
          {
            "name": "total_failed_rows",
            "expr": "SUM(source.failed_rows)",
            "displayName": "Total Failed Rows",
            "comment": "Sum of failed rows across checks."
          },
          {
            "name": "total_rows_checked",
            "expr": "SUM(source.total_rows)",
            "displayName": "Total Rows Checked",
            "comment": "Sum of rows evaluated across checked tables."
          },
          {
            "name": "failure_rate",
            "expr": "MEASURE(failed_checks) * 1.0 / NULLIF(MEASURE(total_checks), 0)",
            "displayName": "Failure Rate",
            "comment": "Percentage of checks that failed."
          }
        ]
      }
    }
  ],
